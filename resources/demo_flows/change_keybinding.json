{
  "flow_name": "Change Keybinding Workflow",
  "steps": [
    {
      "delay_ms": 2000,
      "target": { "type": "Widget", "value": { "id": "settings_btn" } },
      "message": { "Settings": "Open" }
    },
    {
      "delay_ms": 1500,
      "target": { "type": "Widget", "value": { "id": "settings_tab_keybindings" } },
      "message": { "Settings": "OpenKeybindings" }
    },
    {
      "delay_ms": 1500,
      "target": { "type": "Widget", "value": { "id": "keybinding_edit_3" } },
      "message": { "Settings": { "EditKeyBinding": 3 } }
    },
    {
      "delay_ms": 2000,
      "target": { "type": "Widget", "value": { "id": "keybinding_edit_3" } },
      "message": { "KeyCaptured": ["N", false, false, false] }
    },
    {
      "delay_ms": 2000,
      "target": { "type": "Widget", "value": { "id": "close_settings_btn" } },
      "message": { "Settings": "Close" }
    },
    {
      "delay_ms": 1500,
      "target": { "type": "Widget", "value": { "id": "close_settings_btn" } },
      "message": "Quit"
    }
  ]
}
