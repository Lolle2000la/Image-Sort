<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
    <link rel="canonical" href="/en/" />
    <meta name="robots" content="noindex" />
    <script is:inline>
      (function() {
        const supported = ['de', 'ja'];
        const userLangs = navigator.languages || [navigator.language || 'en'];
        let target = 'en';
        for (const lang of userLangs) {
          const code = lang.split('-')[0].toLowerCase();
          if (supported.includes(code)) {
            target = code;
            break;
          }
          if (code === 'en') {
            break;
          }
        }
        window.location.replace('/' + target + '/');
      })();
    </script>
    <meta http-equiv="refresh" content="2;url=/en/" />
  </head>
  <body>
    <p>Redirecting to <a href="/en/">English version</a>, <a href="/de/">Deutsche Version</a>, or <a href="/ja/">日本語版</a>...</p>
  </body>
</html>
