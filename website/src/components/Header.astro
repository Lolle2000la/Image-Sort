---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch = config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const locale = Astro.props.locale;
const docsUrl = locale ? `/${locale}/getting-started/installation/` : '/en/getting-started/installation/';

const labels: Record<string, string> = {
  en: "Documentation",
  de: "Dokumentation",
  ja: "ドキュメント"
};
const label = labels[locale ?? 'en'] || labels.en;
---

<div class="header">
	<div class="title-wrapper sl-flex">
		<SiteTitle />
	</div>

	<div class="search-container sl-flex print:hidden">
		{shouldRenderSearch && <Search />}
	</div>

	<div class="sl-hidden md:sl-flex print:hidden right-group">
		<a href={docsUrl} class="docs-nav-link">{label}</a>
		<div class="sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<LanguageSelect />
	</div>
</div>

<style>
	@layer starlight.core {
		.header {
			display: flex;
			gap: var(--sl-nav-gap);
			justify-content: space-between;
			align-items: center;
			height: 100%;
		}
		.title-wrapper {
			/* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
			overflow: clip;
			/* Avoid clipping focus ring around link inside title wrapper. */
			padding: 0.25rem;
			margin: -0.25rem;
			min-width: 0;
		}
		.right-group,
		.social-icons {
			gap: 1rem;
			align-items: center;
		}
		.social-icons::after {
			content: '';
			height: 2rem;
			border-inline-end: 1px solid var(--sl-color-gray-5);
		}
		.docs-nav-link {
			color: var(--sl-color-gray-3);
			text-decoration: none;
			font-weight: 500;
			font-size: 0.95rem;
			transition: color 0.2s;
		}
		.docs-nav-link:hover {
			color: var(--sl-color-white);
		}
		.search-container {
			flex: 1;
			max-width: 22rem;
			margin: 0 auto;
		}
		@media (min-width: 50rem) {
			:global(:root[data-has-sidebar]) {
				--__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
			}
			:global(:root:not([data-has-toc])) {
				--__toc-width: 0rem;
			}
			.header {
				--__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
			}
		}
	}
</style>
