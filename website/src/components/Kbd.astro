---
export interface Props {
    keys?: string[];
}

const { keys } = Astro.props;

let parts: string[] = [];
if (!keys) {
    const slot = await Astro.slots.render('default');
    parts = slot
        .trim()
        .split('+')
        .map((k) => k.trim())
        .filter(Boolean);
} else {
    parts = keys;
}
---

<span class="kbd-combo">
    {
        parts.flatMap((k, i) => [
            <kbd>{k}</kbd>,
            i < parts.length - 1 && <span class="kbd-sep">+</span>,
        ])
    }
</span>

<style>
    .kbd-combo {
        display: inline-flex;
        align-items: center;
        gap: 0.25em;
        vertical-align: middle;
        white-space: nowrap;
    }
    kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.5em;
        font-family: var(--__sl-font-mono);
        font-size: 0.82em;
        font-weight: 500;
        line-height: 1;
        padding: 0.2em 0.45em;
        border: 1px solid var(--sl-color-gray-4);
        border-bottom-width: 2px;
        border-radius: 0.3rem;
        background: var(--sl-color-gray-6);
        color: var(--sl-color-text);
        box-shadow: 0 1px 0 var(--sl-color-gray-3);
    }
    .kbd-sep {
        font-size: 0.85em;
        color: var(--sl-color-gray-2);
        line-height: 1;
    }
</style>
