<UserControl x:Class="ImageSort.Avalonia.Views.FolderTreeItemView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:ImageSort.ViewModels"
             x:DataType="vm:FolderTreeItemViewModel"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Horizontal" Margin="3">
        <Image Name="FolderIcon"
               Margin="0,0,5,0" />
        <TextBlock Name="FolderName" Text="{Binding FolderName}"/>
    </StackPanel>
</UserControl>
